# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# API key for authenticating requests (X-API-Key header)
ZYPHRAXIS_API_KEY=zyphraxis-demo-key

# Optimisation weights (optional overrides)
WEIGHT_TIME=5.0
WEIGHT_RISK=3.0
WEIGHT_COST=0.01
WEIGHT_HLA_MISMATCH=10.0

# Clinical thresholds
THRESHOLD_MAX_RISK=0.30
THRESHOLD_MIN_ESCAPE_H=24

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/zyphraxis.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Streamlit UI → API URL
API_URL=http://localhost:8000
